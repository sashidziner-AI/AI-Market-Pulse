# OPENAI_API_KEY: Required for OpenAI API calls.
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# HUNTER_API_KEY: Optional. Enables real stakeholder enrichment (name + LinkedIn profile URL)
# via Hunter.io Domain Search. Free tier = 25 searches/mo. If missing, the app falls back
# to the local synthesized-name placeholder.
# Obtain from https://hunter.io/api-keys
HUNTER_API_KEY=""
